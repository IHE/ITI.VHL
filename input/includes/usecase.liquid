{% comment %}
  usecase.liquid
  Renders an ExampleScenario use case: description, process flow with
  pre-conditions, steps, and post-conditions.

  Parameters:
    scenario - ExampleScenario resource from site.data
    site     - the site object

  Fields via R5 cross-version extension URLs (consistent with usecase-list.liquid):
    description -> http://hl7.org/fhir/5.0/StructureDefinition/extension-ExampleScenario.description (valueMarkdown)

  Native R4 process fields accessed directly:
    process[0].title, process[0].description, process[0].preConditions,
    process[0].postConditions, process[0].step[n].operation

  Usage:
    {% assign uc = site.data.ExampleScenario-UseCaseHajjPilgrimage %}
    {% include usecase.liquid site=site scenario=uc %}
{% endcomment %}

{% assign _ext_desc = "http://hl7.org/fhir/5.0/StructureDefinition/extension-ExampleScenario.description" %}
{% assign _description = scenario.extension | where: "url", _ext_desc | first %}

{% if _description %}
{{ _description.valueMarkdown | markdownify }}
{% endif %}

{% assign _process = scenario.process | first %}
{% if _process %}

{% if _process.preConditions %}
<p><b>Pre-conditions:</b></p>
{{ _process.preConditions | markdownify }}
{% endif %}

{% if _process.step and _process.step.size > 0 %}
<p><b>Main Flow:</b></p>
<ol>
{% for _step in _process.step %}
  {% if _step.operation %}
  <li><b>{{ _step.operation.name }}</b>: {{ _step.operation.description | markdownify }}</li>
  {% endif %}
{% endfor %}
</ol>
{% endif %}

{% if _process.postConditions %}
<p><b>Post-conditions:</b></p>
{{ _process.postConditions | markdownify }}
{% endif %}

{% endif %}
