{% comment %}
  usecase-list.liquid
  Renders all ExampleScenario instances that carry usecase-sort-order extension,
  sorted by that order, at the heading level specified by usecase-heading-level.

  Required extensions per instance:
    usecase-sort-order     (valueString, zero-padded 4-digit e.g. "0110")
    usecase-section-number (valueString, e.g. "XX.4.2.1.1")
    usecase-heading-level  (valueInteger, 4 or 5)

  R4 fields (may appear as native fields or R5 cross-version extensions
  depending on IG Publisher version):
    name    (string)   - used as the heading title
    purpose (markdown) - rendered as the use case description

  Usage: {% include usecase-list.liquid site=site %}
{% endcomment %}

{% assign _ext_sort    = "https://profiles.ihe.net/ITI/VHL/StructureDefinition/usecase-sort-order" %}
{% assign _ext_section = "https://profiles.ihe.net/ITI/VHL/StructureDefinition/usecase-section-number" %}
{% assign _ext_level   = "https://profiles.ihe.net/ITI/VHL/StructureDefinition/usecase-heading-level" %}
{% assign _ext_name    = "http://hl7.org/fhir/5.0/StructureDefinition/extension-ExampleScenario.name" %}
{% assign _ext_purpose = "http://hl7.org/fhir/5.0/StructureDefinition/extension-ExampleScenario.purpose" %}

{% comment %} Build sortable "sortKey|stub" token string from all ExampleScenario canonicals {% endcomment %}
{% assign _uc_canonicals = site.data.canonicals | where: 'type', 'ExampleScenario' %}
{% assign _sort_tokens = "" %}
{% for _canonical in _uc_canonicals %}
  {% assign _stub     = "ExampleScenario-" | append: _canonical.id %}
  {% assign _scenario = site.data[_stub] %}
  {% assign _sort_ext = _scenario.extension | where: "url", _ext_sort | first %}
  {% if _sort_ext %}
    {% assign _sort_key = _sort_ext.valueString %}
    {% assign _token    = _sort_key | append: "|" | append: _stub %}
    {% if _sort_tokens == "" %}
      {% assign _sort_tokens = _token %}
    {% else %}
      {% assign _sort_tokens = _sort_tokens | append: "," | append: _token %}
    {% endif %}
  {% endif %}
{% endfor %}

{% comment %} Lexicographic sort works correctly on zero-padded sort keys {% endcomment %}
{% assign _sorted_tokens = _sort_tokens | split: "," | sort %}

{% comment %} Render each use case in sorted order {% endcomment %}
{% for _token in _sorted_tokens %}
  {% assign _parts    = _token | split: "|" %}
  {% assign _stub     = _parts[1] %}
  {% assign _scenario = site.data[_stub] %}

  {% assign _section_ext = _scenario.extension | where: "url", _ext_section | first %}
  {% assign _level_ext   = _scenario.extension | where: "url", _ext_level   | first %}

  {% assign _section_str = _section_ext.valueString  | default: "XX.4.2.X" %}
  {% assign _level_int   = _level_ext.valueInteger   | default: 4 %}

  {% assign _title_str = _scenario.name %}
  {% unless _title_str %}
    {% assign _title_str = _scenario.extension | where: "url", _ext_name | first | map: "valueString" %}
  {% endunless %}
  {% assign _title_str = _title_str | default: _stub %}

  {% assign _purpose_md = _scenario.purpose %}
  {% unless _purpose_md %}
    {% assign _purpose_md = _scenario.extension | where: "url", _ext_purpose | first | map: "valueMarkdown" %}
  {% endunless %}

  {% if _level_int == 5 %}
<h5 id="{{ _stub }}">{{ _section_str }} {{ _title_str }}</h5>
  {% else %}
<h4 id="{{ _stub }}">{{ _section_str }} {{ _title_str }}</h4>
  {% endif %}

{{ _purpose_md | markdownify }}

{% endfor %}
